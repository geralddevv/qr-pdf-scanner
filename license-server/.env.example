# Copy to .env and fill in. Never commit the real .env.

PORT=3000

# bcrypt hash of the admin password. Generate with:
#   node -e "console.log(require('bcryptjs').hashSync('your-password-here', 10))"
ADMIN_PASSWORD_HASH=

# Long random string used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=

# Set to "true" as soon as this runs behind any reverse proxy (nginx/Caddy),
# even before HTTPS is set up. Without this, req.ip becomes the proxy's IP for
# every request, which breaks both the /api/activate rate limiter (all
# clients share one bucket) and the audit log's per-IP fraud signal.
TRUST_PROXY=false

# Set to "true" once the server is behind an HTTPS reverse proxy in production,
# so session cookies are marked Secure.
TRUST_PROXY_HTTPS=false

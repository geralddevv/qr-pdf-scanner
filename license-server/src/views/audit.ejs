<%- include('partials/header', { title: 'Audit log — License Admin', showLogout: true }) %>

<div class="page-header">
  <h1>Activation audit log</h1>
</div>

<form action="/admin/audit" method="get" class="row" style="margin-bottom: 8px;">
  <input type="text" name="deviceId" placeholder="Filter by device ID" value="<%= deviceId %>" style="flex: 1; min-width: 200px;" />
  <input type="text" name="licenseCode" placeholder="Filter by license code" value="<%= licenseCode %>" style="flex: 1; min-width: 200px;" />
  <button type="submit">Filter</button>
  <a class="link-button" href="/admin/audit">Clear</a>
</form>

<p class="muted" style="margin-bottom: 20px;">A burst of "rejected_different_device" entries for one license or device is the signal worth investigating.</p>

<table class="list">
  <thead><tr><th>Result</th><th>License code</th><th>Device</th><th>IP</th><th>When</th></tr></thead>
  <tbody>
    <% attempts.forEach(function(a) { %>
      <tr>
        <td><span class="badge attempt-<%= a.result %>"><%= a.result %></span></td>
        <td><code><%= a.license_code %></code></td>
        <td><code><%= a.device_id %></code></td>
        <td class="muted"><%= a.ip || "—" %></td>
        <td class="muted"><%= a.created_at %></td>
      </tr>
    <% }) %>
    <% if (attempts.length === 0) { %>
      <tr><td colspan="5" class="muted">No activation attempts recorded.</td></tr>
    <% } %>
  </tbody>
</table>

<%- include('partials/footer') %>

<%- include('partials/header', { title: 'Log in — License Admin', showLogout: false }) %>

<div class="login-shell">
  <div class="card narrow">
    <div class="icon-badge">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="#002d8f"><path d="M12 2a5 5 0 0 0-5 5v3H6a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8a2 2 0 0 0-2-2h-1V7a5 5 0 0 0-5-5zm-3 8V7a3 3 0 0 1 6 0v3z"/></svg>
    </div>
    <h1 style="text-align:center;">License Admin</h1>
    <p class="muted" style="text-align:center; margin-top:0; margin-bottom:20px;">Sign in to manage licenses and device bindings.</p>
    <% if (error) { %>
      <p class="error"><%= error %></p>
    <% } %>
    <form action="/admin/login" method="post">
      <label for="password">Password</label>
      <input type="password" id="password" name="password" autofocus required />
      <button type="submit">Log in</button>
    </form>
  </div>
</div>

<%- include('partials/footer') %>
